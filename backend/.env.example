# ============================================================================
# Food Store API — Variables de entorno (BACKEND)
# ----------------------------------------------------------------------------
# Copiá este archivo a `backend/.env` y completá los valores reales.
# NUNCA commitees el .env real: contiene secretos. Solo se versiona este ejemplo.
#
# Lo lee app/nucleo/ajustes.py (pydantic-settings). Las claves NO son
# case-sensitive, pero por convención .env se escriben en MAYUSCULAS.
# ============================================================================

# ----------------------------------------------------------------------------
# Base de datos (PostgreSQL)
# ----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=foodstore_new
# Conexion completa. Con docker-compose el host es `base_datos` (nombre del servicio).
# Local sin docker, usa localhost:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foodstore_new

# ----------------------------------------------------------------------------
# Seguridad / JWT
# ----------------------------------------------------------------------------
# Minimo 32 caracteres. Genera una propia en produccion (ej: openssl rand -hex 32).
CLAVE_SECRETA=cambia-esta-clave-minimo-32-caracteres-obligatorio
ALGORITMO=HS256
MINUTOS_ACCESO=30
DIAS_RENOVACION=7

# ----------------------------------------------------------------------------
# Aplicacion
# ----------------------------------------------------------------------------
DEBUG=True
NOMBRE_APP=Food Store API
VERSION=1.0.0
PREFIJO_API=/api/v1
# Origenes permitidos por CORS, separados por coma (frontend Vite + alternativo).
ORIGENES_CORS=http://localhost:5173,http://localhost:3000

# ----------------------------------------------------------------------------
# Cloudinary (CDN de imagenes) — credenciales del BACKEND (signed upload).
# Panel: https://console.cloudinary.com/  ->  Dashboard -> Account Details
# El api_secret JAMAS se expone al frontend.
# ----------------------------------------------------------------------------
NUBE_CDN=tu-cloud-name
API_KEY_CDN=123456789012345
API_SECRET_CDN=tu-api-secret-de-cloudinary
TAMANIO_MAXIMO_MB=5

# ----------------------------------------------------------------------------
# MercadoPago — credenciales del BACKEND.
# Panel: https://www.mercadopago.com.ar/developers/panel/app  ->  Credenciales
# Usa las de PRUEBA (TEST-...) para sandbox.
# ----------------------------------------------------------------------------
TOKEN_MP=TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
# La Public Key tambien la usa el FRONTEND (ver frontend/.env.example -> VITE_CLAVE_PUBLICA_MP).
CLAVE_PUBLICA_MP=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Secreto para validar la firma del webhook IPN (panel MP -> Webhooks).
SECRETO_WEBHOOK_MP=tu-secreto-de-webhook

# ----------------------------------------------------------------------------
# ngrok — URL publica del backend para que MercadoPago entregue el webhook.
# ----------------------------------------------------------------------------
# MercadoPago necesita una URL publica (HTTPS) para notificar pagos al endpoint
# POST /api/v1/cobros/webhook. En desarrollo se expone el backend con ngrok:
#     ngrok http 8000
# y se carga la URL publica resultante en el panel de MP (Webhooks) apuntando a
# https://<tu-subdominio>.ngrok-free.app/api/v1/cobros/webhook
#
# NOTA: hoy el codigo NO lee esta variable (el webhook se configura en el panel
# de MP). Queda declarada para cuando se cablee notification_url en crear_preferencia.
URL_PUBLICA_BACKEND=https://tu-subdominio.ngrok-free.app
# El authtoken de ngrok NO va aca: se configura una sola vez con
#     ngrok config add-authtoken <tu-authtoken>