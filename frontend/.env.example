# ============================================================================
# Food Store — Variables de entorno (FRONTEND / Vite)
# ----------------------------------------------------------------------------
# Copia este archivo a `frontend/.env` y completa los valores.
# Solo las variables con prefijo VITE_ quedan expuestas al navegador, asi que
# NUNCA pongas aca secretos del backend (api_secret de Cloudinary, token_mp, etc).
# ============================================================================

# URL base de la API REST del backend.
VITE_URL_API=http://localhost:8000

# URL del WebSocket del backend (ws:// en local, wss:// detras de HTTPS/ngrok).
VITE_URL_WS=ws://localhost:8000

# ----------------------------------------------------------------------------
# MercadoPago — Public Key para el checkout en el navegador.
# Es la MISMA Public Key del backend (CLAVE_PUBLICA_MP). La Public Key es
# segura de exponer; el Access Token (secreto) NUNCA va en el frontend.
# NOTA: hoy el codigo del frontend todavia NO lee esta variable (la integracion
# de MercadoPago en el front esta pendiente — ver punto C3 de la auditoria).
# ----------------------------------------------------------------------------
VITE_CLAVE_PUBLICA_MP=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx